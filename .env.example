# BFF caisse — déploiement sur l'infra iwm partagée. Copier en .env et compléter.

# Base partagée (même mot de passe que le Postgres iwm)
IWM_DB_USER=iwm
IWM_DB_PASSWORD=change-me-meme-mdp-que-iwm
CASHIER_DB_NAME=erp_cashier

# Secret JWT du BFF (>= 32 caractères) : openssl rand -hex 24
APP_JWT_SECRET=change-me-jwt-secret-32-chars-minimum

# Port public exposé sur la VM (le frontend pointe dessus)
CASHIER_BACKEND_PUBLIC_PORT=8094
