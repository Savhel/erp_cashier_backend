# BFF caisse — déploiement sur l'infra iwm partagée. Copier en .env et compléter.

# Base partagée (même mot de passe que le Postgres iwm)
IWM_DB_USER=iwm
IWM_DB_PASSWORD=change-me-meme-mdp-que-iwm
CASHIER_DB_NAME=erp_cashier

# Secret JWT du BFF (>= 32 caractères) : openssl rand -hex 24
# (inutile en mode passthrough-all : le JWT vient d'iwm)
APP_JWT_SECRET=change-me-jwt-secret-32-chars-minimum

# --- Mode façade pure (recommandé : tout dans iwm) ---
# true  → le BFF relaie TOUT /api/* vers iwm (auth incluse), aucune logique/BD locale.
#         La base CASHIER_DB_NAME devient inutile.
# false → ancien comportement (logique + BD locale). À basculer après validation runtime.
CASHIER_CORE_PASSTHROUGH_ALL=false
# Tenant injecté dans X-Tenant-Id lors du login délégué à iwm
RT_TENANT_ID=11111111-1111-1111-1111-111111111111

# Port public exposé sur la VM (le frontend pointe dessus)
CASHIER_BACKEND_PUBLIC_PORT=8094

# Traefik : base d'hôte public (= <IP_VM>.nip.io)
PUBLIC_HOST=CHANGE_ME.nip.io
